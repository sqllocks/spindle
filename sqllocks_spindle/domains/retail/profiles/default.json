{
  "name": "default",
  "description": "Calibrated US retail/e-commerce distribution profile",
  "source": "Calibrated from NRF, US Census, Statista, Shopify, and industry data (2024)",
  "distributions": {
    "customer.gender": {"M": 0.49, "F": 0.51},
    "customer.loyalty_tier": {"Basic": 0.55, "Silver": 0.25, "Gold": 0.13, "Platinum": 0.07},
    "customer.is_active": {"true": 0.85, "false": 0.15},

    "address.address_type": {"billing": 0.50, "shipping": 0.40, "both": 0.10},

    "product.product_status": {
      "phases": [
        {"name": "introduced", "weight": 0.08},
        {"name": "active", "weight": 0.75},
        {"name": "discontinued", "weight": 0.17}
      ]
    },

    "store.store_type": {"physical": 0.85, "online": 0.10, "warehouse": 0.05},

    "promotion.promotion_type": {"percent_off": 0.40, "bogo": 0.15, "fixed_amount": 0.20, "bundle": 0.10, "free_shipping": 0.15},
    "promotion.discount_pct": {"5.0": 0.05, "10.0": 0.25, "15.0": 0.20, "20.0": 0.25, "25.0": 0.10, "50.0": 0.15},

    "order.customer_id": {"distribution": "pareto", "alpha": 1.16, "max_per_parent": 50},
    "order.store_id": {"distribution": "zipf", "alpha": 1.3},
    "order.status": {"completed": 0.77, "shipped": 0.08, "processing": 0.02, "cancelled": 0.04, "returned": 0.09},
    "order.order_date.month": {
      "Jan": 0.071, "Feb": 0.068, "Mar": 0.079, "Apr": 0.079, "May": 0.083, "Jun": 0.083,
      "Jul": 0.085, "Aug": 0.088, "Sep": 0.079, "Oct": 0.083, "Nov": 0.096, "Dec": 0.106
    },
    "order.order_date.day_of_week": {
      "Mon": 0.155, "Tue": 0.152, "Wed": 0.148, "Thu": 0.153, "Fri": 0.147, "Sat": 0.115, "Sun": 0.130
    },
    "order.order_date.hour_of_day": {"peaks": [12, 20], "std_dev": 2},

    "order_line.product_id": {"distribution": "zipf", "alpha": 1.5},
    "order_line.quantity": {"distribution": "geometric", "p": 0.6, "min": 1, "max": 20},

    "return.reason": {"wrong_size": 0.25, "changed_mind": 0.22, "not_as_described": 0.20, "defective": 0.15, "damaged_shipping": 0.10, "arrived_late": 0.05, "other": 0.03}
  },
  "ratios": {
    "address_per_customer": 1.5,
    "order_line_per_order": 2.5,
    "return_per_order": 0.17
  }
}
